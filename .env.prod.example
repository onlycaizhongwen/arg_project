# Production configuration checklist template.
# Do not copy real secrets into this file. Use a secret manager, CI/CD protected
# variables, or the deployment platform's secret injection mechanism.

APP_ENV=prod
APP_NAME=rag-cleaning-api
APP_VERSION=0.1.0

PYTHON_BASE_IMAGE=<prod-registry>/rag-cleaning/python:3.12-slim
POSTGRES_IMAGE=<prod-registry>/library/postgres:16-alpine
RABBITMQ_IMAGE=<prod-registry>/library/rabbitmq:3.13-management-alpine
MINIO_IMAGE=<prod-registry>/minio/minio:RELEASE.2025-04-22T22-12-26Z
QDRANT_IMAGE=<prod-registry>/qdrant/qdrant:v1.18.0

POSTGRES_HOST=<prod-postgres-host>
POSTGRES_PORT=5432
POSTGRES_DB=rag_cleaning
POSTGRES_USER=<prod-postgres-user>
POSTGRES_PASSWORD=<set-by-secret-manager>

RABBITMQ_HOST=<prod-rabbitmq-host>
RABBITMQ_PORT=5672
RABBITMQ_USER=<prod-rabbitmq-user>
RABBITMQ_PASSWORD=<set-by-secret-manager>
RABBITMQ_QUEUE=cleaning.jobs

MINIO_ENDPOINT=<prod-object-storage-endpoint>
MINIO_ACCESS_KEY=<set-by-secret-manager>
MINIO_SECRET_KEY=<set-by-secret-manager>
MINIO_BUCKET=rag-documents
MINIO_SECURE=true

QDRANT_HOST=<prod-qdrant-host>
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_chunks

# Select one production embedding provider and keep the vector dimension stable.
EMBEDDING_PROVIDER=<dashscope-or-internal_bge>
EMBEDDING_MODEL=<approved-embedding-model>
EMBEDDING_DIMENSION=1024
EMBEDDING_OUTPUT_TYPE=dense
EMBEDDING_BASE_URL=<internal-embedding-endpoint-if-used>
DASHSCOPE_API_KEY=<set-by-secret-manager>

# Enable external rerank only after capacity and ranking-gain evaluation.
RERANK_PROVIDER=disabled
RERANK_MODEL=<approved-rerank-model>
RERANK_BASE_URL=<approved-rerank-endpoint-if-used>
RERANK_TIMEOUT_SECONDS=10
HF_ENDPOINT=<internal-hf-mirror-or-empty>

WORKER_MAX_RETRIES=3

# Production should receive trusted identity and permission headers from IAM/SSO
# or an authenticated gateway. Do not expose the API directly to untrusted users.
AUTH_CONTEXT_MODE=iam
AUTH_TRUSTED_HEADER_ENABLED=true
AUTH_REQUIRE_ACTOR=true
AUTH_REQUIRE_TENANT=true
AUTH_DEFAULT_REQUEST_SOURCE=iam-gateway
AUTH_DEFAULT_PERMISSION_TAGS=public
AUTH_EMPTY_PERMISSION_POLICY=public_only
LOG_LEVEL=INFO
TRACE_ID_HEADER=X-Trace-Id
METRICS_ENABLED=true
