# Test / customer integration environment template.
# Copy this file to .env in the deployment workspace and replace placeholders.
# Do not commit real credentials.

APP_ENV=test
APP_NAME=rag-cleaning-api
APP_VERSION=0.1.0

# Replace with the customer internal registry when public registries are blocked.
PYTHON_BASE_IMAGE=<internal-registry>/library/python:3.12-slim
POSTGRES_IMAGE=<internal-registry>/library/postgres:16-alpine
RABBITMQ_IMAGE=<internal-registry>/library/rabbitmq:3.13-management-alpine
MINIO_IMAGE=<internal-registry>/minio/minio:RELEASE.2025-04-22T22-12-26Z
QDRANT_IMAGE=<internal-registry>/qdrant/qdrant:v1.18.0

POSTGRES_HOST=<test-postgres-host>
POSTGRES_PORT=5432
POSTGRES_DB=rag_cleaning
POSTGRES_USER=<test-postgres-user>
POSTGRES_PASSWORD=<set-in-env-or-secret-manager>

RABBITMQ_HOST=<test-rabbitmq-host>
RABBITMQ_PORT=5672
RABBITMQ_USER=<test-rabbitmq-user>
RABBITMQ_PASSWORD=<set-in-env-or-secret-manager>
RABBITMQ_QUEUE=cleaning.jobs

MINIO_ENDPOINT=<test-minio-host>:9000
MINIO_ACCESS_KEY=<test-minio-access-key>
MINIO_SECRET_KEY=<set-in-env-or-secret-manager>
MINIO_BUCKET=rag-documents
MINIO_SECURE=false

QDRANT_HOST=<test-qdrant-host>
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_chunks

# Choose one embedding provider for a test environment.
# Option A: internal BGE-compatible embedding service.
EMBEDDING_PROVIDER=local_bge
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_OUTPUT_TYPE=dense
EMBEDDING_BASE_URL=http://<test-bge-host>:11434

# Option B: DashScope text-embedding-v4.
# EMBEDDING_PROVIDER=dashscope
# EMBEDDING_MODEL=text-embedding-v4
# EMBEDDING_DIMENSION=1024
# EMBEDDING_OUTPUT_TYPE=dense
# DASHSCOPE_API_KEY=<set-in-env-or-secret-manager>
DASHSCOPE_API_KEY=

# Keep rerank disabled or mock until a real rerank endpoint is sized.
RERANK_PROVIDER=disabled
RERANK_MODEL=BAAI/bge-reranker-base
RERANK_BASE_URL=
RERANK_TIMEOUT_SECONDS=10
HF_ENDPOINT=https://hf-mirror.com

WORKER_MAX_RETRIES=3

# Test environments should receive trusted identity headers from a gateway.
AUTH_CONTEXT_MODE=gateway
AUTH_TRUSTED_HEADER_ENABLED=true
AUTH_REQUIRE_ACTOR=true
AUTH_REQUIRE_TENANT=true
AUTH_DEFAULT_REQUEST_SOURCE=gateway
AUTH_DEFAULT_PERMISSION_TAGS=public
AUTH_EMPTY_PERMISSION_POLICY=public_only
