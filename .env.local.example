# Local PoC / developer environment.
# Copy this file to .env for local demos:
#   Copy-Item .env.local.example .env

APP_ENV=local
APP_NAME=rag-cleaning-api
APP_VERSION=0.1.0

# Mainland China friendly default images. Override these with your own registry
# if your network or customer environment requires it.
PYTHON_BASE_IMAGE=docker.m.daocloud.io/library/python:3.12-slim
POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:16-alpine
RABBITMQ_IMAGE=docker.m.daocloud.io/library/rabbitmq:3.13-management-alpine
MINIO_IMAGE=docker.m.daocloud.io/minio/minio:RELEASE.2025-04-22T22-12-26Z
QDRANT_IMAGE=docker.m.daocloud.io/qdrant/qdrant:v1.18.0

# Host-side access for scripts and manual debugging.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag_cleaning
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=rag
RABBITMQ_PASSWORD=rag
RABBITMQ_QUEUE=cleaning.jobs

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=rag
MINIO_SECRET_KEY=rag_password
MINIO_BUCKET=rag-documents
MINIO_SECURE=false

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_chunks

# Recommended local demo baseline: Ollama bge-m3 embeddings + mock rerank.
# Before using local_bge, run:
#   ollama pull bge-m3
EMBEDDING_PROVIDER=local_bge
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_OUTPUT_TYPE=dense
EMBEDDING_BASE_URL=http://host.docker.internal:11434
DASHSCOPE_API_KEY=

RERANK_PROVIDER=mock
RERANK_MODEL=mock-reranker
RERANK_BASE_URL=
RERANK_TIMEOUT_SECONDS=5
HF_ENDPOINT=https://hf-mirror.com

# Optional real local reranker. Uncomment when enabling the reranker profile:
# COMPOSE_PROFILES=reranker
# RERANK_PROVIDER=external
# RERANK_MODEL=BAAI/bge-reranker-base
# RERANK_BASE_URL=http://reranker:8010/rerank
# RERANK_TIMEOUT_SECONDS=30

WORKER_MAX_RETRIES=3

# Local mode keeps PoC scripts simple. Test/prod should use gateway or iam.
AUTH_CONTEXT_MODE=local
AUTH_TRUSTED_HEADER_ENABLED=true
AUTH_REQUIRE_ACTOR=false
AUTH_REQUIRE_TENANT=false
AUTH_DEFAULT_REQUEST_SOURCE=api
AUTH_DEFAULT_PERMISSION_TAGS=public
AUTH_EMPTY_PERMISSION_POLICY=public_only
